{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "asociacion mutual el rosario",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ASOCIACION MUTUAL EL ROSARIO LIBORINA",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/mutual.sqlite"],
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon-512.png",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
